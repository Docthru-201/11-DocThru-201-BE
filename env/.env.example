# 환경 변수 예시 파일

# 로컬 postgres에 doc_thru DB 생성
# .env.example 복사 -> .env.development, .env.production 파일 생성 (username, password 수정)
# pnpm prisma:migrate 실행

# 환경 설정
NODE_ENV=development

# 서버 포트
PORT=5001

# PostgreSQL 연결 URL
DATABASE_URL="postgresql://username:password@localhost:5432/doc_thru"

# JWT 시크릿 키 (임시, 가짜 값)
JWT_ACCESS_SECRET=abcdefghijklmnopqrstuvwxyz123456
JWT_REFRESH_SECRET=zyxwvutsrqponmlkjihgfedcba654321

API_BASE_URL=http://localhost:5001/
CLIENT_BASE_URL=http://localhost:3000/

# OAuth (Google) 설정
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=