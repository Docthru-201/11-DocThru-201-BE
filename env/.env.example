# нҷҳкІҪ ліҖмҲҳ мҳҲмӢң нҢҢмқј

# лЎңм»¬ postgresм—җ doc_thru DB мғқм„ұ
# .env.example ліөмӮ¬ -> .env.development, .env.production нҢҢмқј мғқм„ұ (username, password мҲҳм •)
# npm prisma:migrate мӢӨн–ү

# нҷҳкІҪ м„Өм •
NODE_ENV=development

# м„ңлІ„ нҸ¬нҠё
PORT=5001

# PostgreSQL м—°кІ° URL
DATABASE_URL="postgresql://username:password@localhost:5432/doc_thru"

# JWT мӢңнҒ¬лҰҝ нӮӨ
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

API_BASE_URL=http://localhost:5001/
CLIENT_BASE_URL=http://localhost:3000/

# OAuth (Google) м„Өм •
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=